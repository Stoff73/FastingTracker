<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!--
        Fasting Tracker — Privacy Manifest (PrivacyInfo.xcprivacy)
        All user data is stored locally on device via SwiftData.
        No data is transmitted to external servers.
        No third-party analytics, advertising, or tracking SDKs are used.
    -->

    <!-- App does not track users across apps or websites -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No tracking domains (no network calls) -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- ── Data types collected ────────────────────────────────────────── -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>

        <!--
            Health & Fitness
            Fasting session durations, stages reached, targets set.
            Stored locally only. Never linked to identity or used for tracking.
        -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeHealth</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!--
            User Content
            Mood emoji selections and optional fast notes entered by the user.
            Stored locally only. Never linked to identity or used for tracking.
        -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherUserContent</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!--
            Name
            Display name entered during onboarding and stored in UserProfile.
            Stored locally only. Never linked to identity or used for tracking.
        -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeName</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

    </array>

    <!-- ── Required reason APIs ───────────────────────────────────────── -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>

        <!--
            File Timestamp APIs
            Used by SwiftData to persist fasting sessions, user profiles,
            and friend records to the app's local container on disk.
            Reason C617.1: access timestamps of files in the app's own container.
        -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>C617.1</string>
            </array>
        </dict>

        <!--
            System Boot Time
            Used to compute elapsed fasting time via monotonic clock references
            when calculating timer intervals for the active fasting session.
            Reason 35F9.1: measure elapsed time for app functionality.
        -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategorySystemBootTime</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>35F9.1</string>
            </array>
        </dict>

    </array>

</dict>
</plist>
